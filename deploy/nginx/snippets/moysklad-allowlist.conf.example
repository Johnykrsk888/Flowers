# Пример: разрешить прокси МойСклад только с офиса/VPN (иначе для публичного магазина НЕ используйте —
# посетители сайта не смогут загрузить каталог).
#
# Раскомментируйте и подставьте свои сети, затем:
#   include /etc/nginx/snippets/moysklad-allowlist.conf;
# в начале блока location /api/moysklad/ и location ~ download (перед proxy_pass).
#
# allow 203.0.113.0/24;
# allow 2001:db8::/32;
# deny all;
